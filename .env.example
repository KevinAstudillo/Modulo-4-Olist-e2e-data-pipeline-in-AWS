# =============================================================
#  .env.example — Copia este archivo como .env y rellena los valores
#  NUNCA subas el archivo .env real a GitHub
# =============================================================

# ── Kaggle ────────────────────────────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
KAGGLE_DATASET=olistbr/brazilian-ecommerce

# ── AWS ───────────────────────────────────────────────────────
# Obtén estos 3 valores desde AWS Academy → "AWS Details" → "Show" (AWS CLI)
# OJO: expiran al terminar la sesión del lab, debes actualizarlos cada vez
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=your_aws_session_token
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
S3_BRONZE_PREFIX=bronze/olist/

# ── Aurora PostgreSQL ─────────────────────────────────────────
# AURORA_HOST: RDS → aurora-mod4-instance-1 → Connectivity → Endpoint
AURORA_HOST=aurora-mod4.cluster-xxxx.us-east-1.rds.amazonaws.com
AURORA_PORT=5432
AURORA_DATABASE=postgres
AURORA_USERNAME=postgres
AURORA_PASSWORD=your_aurora_master_password
AURORA_CLUSTER_ID=aurora-mod4

# ── Aplicación ────────────────────────────────────────────────
LOG_LEVEL=INFO
RAW_DATA_DIR=data/raw
